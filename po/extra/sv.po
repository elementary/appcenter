msgid "Updated translations"
msgstr "Uppdaterade översättningar"

#: data/appcenter.metainfo.xml.in:73
#, fuzzy
#| msgid "Other Improvements:"
msgid "Performance improvements"
msgstr "Andra förbättringar:"

#: data/appcenter.metainfo.xml.in:179 data/appcenter.metainfo.xml.in:209
#: data/appcenter.metainfo.xml.in:229 data/appcenter.metainfo.xml.in:257
msgid "New features:"
msgstr "Nya funktioner:"

#: data/appcenter.metainfo.xml.in:181
msgid "Manage autostart in System Settings → Applications"
msgstr "Hantera automatisk start i Systeminställningar → Program"

#: data/appcenter.metainfo.xml.in:185
msgid "Automatic app updates by default"
msgstr "Automatiska appuppdateringar som standard"

#: data/appcenter.metainfo.xml.in:186
msgid "OS Updates have moved to System Settings"
msgstr "OS-uppdateringar har flyttats till Systeminställningar"

#: data/appcenter.metainfo.xml.in:187
msgid ""
"Badge apps made for elementary OS instead of badging apps from other remotes"
msgstr ""
"Märk appar som är gjorda för elementary OS istället för att märka appar från "
"andra fjärrservrar"

#: data/appcenter.metainfo.xml.in:211
msgid "Warn when apps use legacy Autostart, Notifications"
msgstr "Varna när appar använder föråldrade Autostart, Meddelanden"

#: data/appcenter.metainfo.xml.in:215
msgid "Fix flickering on AppInfo views when getting install size"
msgstr "Fixa flimmer på AppInfo-vyer vid hämtning av installationsstorlek"

#: data/appcenter.metainfo.xml.in:231
msgid ""
"Warn when apps have access to Home or system folders, location, settings, or "
"have an insecure sandbox."
msgstr ""
"Varna när appar har åtkomst till hem- eller systemmappar, plats, "
"inställningar eller har en osäker sandlåda."

#: data/appcenter.metainfo.xml.in:235
msgid "Tighten up spacing and margins in App Info views"
msgstr "Strama upp avstånd och marginaler i App Info-vyer"

#: data/appcenter.metainfo.xml.in:236
msgid "Show a placeholder banner on the home page when loading"
msgstr "Visa en platshållarbanderoll på startsidan när den läses in"

#: data/appcenter.metainfo.xml.in:237
msgid "Don't list non-AppCenter apps under a separate header in category views"
msgstr ""
"Lista inte appar som inte tillhör AppCenter under en separat rubrik i "
"kategorivyer"

#: data/appcenter.metainfo.xml.in:259
msgid "Offer a Repair option if Flatpak updates fail"
msgstr "Erbjud ett reparationsalternativ om Flatpak-uppdateringar misslyckas"

#: data/appcenter.metainfo.xml.in:260
msgid ""
"Show a message in the updates view when up to date, including when updates "
"were last checked"
msgstr ""
"Visa ett meddelande i uppdateringsvyn när uppdateringarna är aktuella, "
"inklusive när uppdateringarna senast kontrollerades"

#: data/io.elementary.appcenter.desktop.in.in:8
msgid "install;uninstall;remove;catalogue;store;apps;software;"
msgstr "installera;avinstallera;ta bort;katalogisera;lagra;appar;programvara;"

#: data/io.elementary.appcenter.desktop.in.in:25
msgid "Check for Updates"
msgstr "Leta efter uppdateringar"

#: data/io.elementary.appcenter.policy.in:10
msgid "Repair software sources"
msgstr "Reparera programvarukällor"

#: data/io.elementary.appcenter.policy.in:11
msgid "Authentication is required to repair software sources"
msgstr "Autentisering krävs för att reparera programvarukällor"

